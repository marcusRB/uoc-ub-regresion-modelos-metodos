set.seed(123)
x <- 1:20
y <- x + rnorm(20)
# Crearemos la función para calcular beta por método directo (X'X)^{-1} X'y
direct_lm <- function(formula, data) {
X <- model.matrix(formula, data)
beta <- solve(t(X) %*% X) %*% t(X) %*% data$y
return(beta)
}
#  Utilizamos try..cath para evitar de no ejecutarse correctamente
for (d in 1:10) {
f <- as.formula(paste("y ~ poly(x,", d, ", raw=TRUE)"))
mod <- lm(f, data.frame(x = x, y = y))
beta_lm <- coef(mod)
# Intentar método directo con captura de error
beta_direct <- tryCatch({
direct_lm(f, data.frame(x = x, y = y))
}, error = function(e) {
cat("Grado", d, ": método directo falla -", e$message, "\n")
return(NA)
})
if (!any(is.na(beta_direct))) {
diff_max <- max(abs(beta_lm - beta_direct))
cat("Grado", d, "diferencia máxima:", diff_max, "\n")
}
}
