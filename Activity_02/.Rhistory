X <- model.matrix(mod_full)
y <- truck$height
# Descomposición QR con pivoteo
qrX <- qr(X)
# Matriz Q (solo las primeras p columnas)
Q <- qr.Q(qrX)
# Matriz R (completa, p x p)
R <- qr.R(qrX)
# f = Q^T y
f <- t(Q) %*% y
# Resolver R * beta = f
beta_qr <- try(backsolve(R, f), silent = TRUE)
print(beta_qr)
beta_qr_coef <- qr.coef(qrX, y)
print(beta_qr_coef)
