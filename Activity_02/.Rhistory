par(mfrow = c(1, 1))
plot(lpsa ~ lcavol, data = prostate)
mod1 <- lm(lpsa ~ lcavol, data = prostate)
mod2 <- lm(lcavol ~ lpsa, data = prostate)
abline(mod1, col = "blue")
abline(mod2, col = "red")
# Intersección: resolver las dos ecuaciones
# lpsa = a + b*lcavol
# lcavol = c + d*lpsa  => lpsa = (lcavol - c)/d
# Igualando: a + b*lcavol = (lcavol - c)/d  => despejar lcavol
# Se obtiene lcavol = (a*d + c) / (1 - b*d)
# Luego se sustituye.
a <- coef(mod1)[1]; b <- coef(mod1)[2]
c <- coef(mod2)[1]; d <- coef(mod2)[2]
lcavol_int <- (a*d + c) / (1 - b*d)
lpsa_int <- a + b * lcavol_int
points(lcavol_int, lpsa_int, pch = 19, cex = 2)
