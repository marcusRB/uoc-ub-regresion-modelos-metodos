truck$C <- ifelse(truck$C == "-", -1, 1)
truck$D <- ifelse(truck$D == "-", -1, 1)
truck$E <- ifelse(truck$E == "-", -1, 1)
truck$O <- ifelse(truck$O == "-", -1, 1)
mod_full <- lm(height ~ B + C + D + E + O, data = truck)
