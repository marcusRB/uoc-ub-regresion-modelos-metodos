# Datos conocidos
a        <- 6        # número de grupos
MS_grupo <- 11.8     # cuadrado medio del grupo
F_val    <- 20.6     # estadístico F
SS_res   <- 13.7     # suma de cuadrados residual
gl_grupo <- a - 1   # grados de libertad del factor = 5
# Realizamos los cálculos
SS_grupo  <- MS_grupo * gl_grupo        # SS = MS * gl
MS_res    <- MS_grupo / F_val           # MS_res = MS_grupo / F
gl_res    <- round(SS_res / MS_res)     # gl_res = SS_res / MS_res
SS_total  <- SS_grupo + SS_res
gl_total  <- gl_grupo + gl_res
n_por_grupo <- (gl_res / a) + 1        # n = gl_res/a + 1 (balanceado)
N            <- n_por_grupo * a
# Creamos la tabla ANOVA completada
cat("=== TABLA ANOVA COMPLETADA ===\n")
cat(sprintf("gl_grupo   = %d\n", gl_grupo))
cat(sprintf("SS_grupo   = %.1f\n", SS_grupo))
cat(sprintf("MS_grupo   = %.1f\n", MS_grupo))
cat(sprintf("F          = %.1f\n\n", F_val))
cat(sprintf("gl_res     = %d\n", gl_res))
cat(sprintf("SS_res     = %.1f\n", SS_res))
cat(sprintf("MS_res     = %.4f\n\n", MS_res))
cat(sprintf("gl_total   = %d\n", gl_total))
cat(sprintf("SS_total   = %.1f\n\n", SS_total))
cat(sprintf("N total    = %d\n", N))
cat(sprintf("n por grupo = %d\n", n_por_grupo))
# P-valor del test F
p_valor_p2 <- pf(F_val, df1 = gl_grupo, df2 = gl_res, lower.tail = FALSE)
cat(sprintf("\nP-valor:   %s\n", format(p_valor_p2, digits = 4)))
# Medias de los grupos
medias_p2 <- c(y1 = 4.6, y2 = 5.3, y3 = 4.5,
y4 = 6.8, y5 = 7.1, y6 = 8.3)
# Parámetros
alpha_p2    <- 0.05
# observaciones por grupo (diseño balanceado)
n_p2        <- n_por_grupo
gl_error_p2 <- gl_res
# Valor crítico t
t_crit_p2 <- qt(1 - alpha_p2 / 2, df = gl_error_p2)
cat(sprintf("t crítico (alpha=0.05, gl=%d): %.4f\n", gl_error_p2, t_crit_p2))
# LSD
LSD <- t_crit_p2 * sqrt(2 * MS_res / n_p2)
cat(sprintf("LSD = %.4f\n\n", LSD))
# Comparaciones por pares
sprintf("=== COMPARACIONES POR PARES ===\n")
pares <- combn(names(medias_p2), 2)
resultados <- data.frame(
Grupo1 = character(),
Grupo2 = character(),
Diferencia = numeric(),
Signifisprintfivo = character(),
stringsAsFactors = FALSE
)
for (k in 1:ncol(pares)) {
g1   <- pares[1, k]
g2   <- pares[2, k]
dif  <- abs(medias_p2[g1] - medias_p2[g2])
sig  <- ifelse(dif > LSD, "Sí ***", "No")
resultados <- rbind(resultados,
data.frame(Grupo1 = g1, Grupo2 = g2,
Diferencia = round(dif, 2),
Signifisprintfivo = sig))
}
print(resultados, row.names = FALSE)
