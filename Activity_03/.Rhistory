# Intervalo de confianza al 95% para la media del grupo con mayor PHA
# IC = media_i ± t_{alpha/2, N-a} * sqrt(MSE / n_i)
n_i  <- 3                        # réplicas por grupo
alfa <- 0.05
gl   <- nrow(df) - nlevels(df$fuente)   # grados de libertad residual = 8
t_cr <- qt(1 - alfa/2, df = gl)
media_mejor <- medias_grupo[mejor]
error_est   <- sqrt(MSE / n_i)
IC_inf <- media_mejor - t_cr * error_est
IC_sup <- media_mejor + t_cr * error_est
sprintf("\nIC al 95% para la media de", mejor, ":\n")
