mu_global - delta,  # grupo 2: -5
mu_global,          # grupo 3: media global
mu_global)          # grupo 4: media global
a <- 4  # número de grupos
# Varianza entre grupos bajo H1 (lambda / n)
# lambda = n * sum((mu_i - mu_global)^2) / sigma^2
# Usamos power.anova.test: between.var = var(medias_H1)
var_entre <- var(medias_H1)   # varianza entre medias de los grupos
cat("Varianza entre grupos (between.var):", round(var_entre, 4), "\n")
cat("Varianza residual  (within.var):    ", round(sigma2, 4),    "\n")
# Cálculo del tamaño muestral
resultado_n <- power.anova.test(
groups      = a,
between.var = var_entre,
within.var  = sigma2,
sig.level   = 0.05,
power       = 0.90,
n           = NULL       # esto es lo que queremos calcular
)
print(resultado_n)
cat("\nTamaño muestral mínimo por grupo:", ceiling(resultado_n$n), "\n")
cat("Total de observaciones:           ", ceiling(resultado_n$n) * a, "\n")
set.seed(42)
B <- 9999   # número de permutaciones
# F observado
F_obs <- summary(aov(modelo))[[1]]["fuente", "F value"]
cat("F observado:", round(F_obs, 4), "\n")
# Permutaciones
F_perm <- numeric(B)
for (b in 1:B) {
pha_perm <- sample(df$pha)   # permutación de la variable respuesta
mod_perm <- lm(pha_perm ~ df$fuente)
F_perm[b] <- anova(mod_perm)["df$fuente", "F value"]
}
# P-valor empírico
p_perm <- mean(F_perm >= F_obs)
cat("P-valor por permutaciones:", round(p_perm, 4), "\n")
cat("P-valor ANOVA clásico:    ", round(tabla_anova["fuente", "Pr(>F)"], 6), "\n")
# Histograma de la distribución nula
hist(F_perm,
breaks = 50,
freq   = FALSE,
main   = "Distribución nula del estadístico F (permutaciones)",
xlab   = "F",
col    = "lightblue",
border = "white")
abline(v = F_obs, col = "red", lwd = 2, lty = 1)
legend("topright",
legend = paste0("F obs = ", round(F_obs, 2)),
col    = "red", lwd = 2, bty = "n")
# Superponemos la distribución F teórica
x_seq <- seq(0, max(F_perm, F_obs) * 1.1, length.out = 300)
lines(x_seq, df(x_seq, df1 = 3, df2 = 8), col = "darkblue", lwd = 2)
legend("right",
legend = c("Permutaciones", "F(3,8) teórica"),
col    = c("lightblue", "darkblue"),
lwd    = c(6, 2), bty = "n")
# Datos conocidos
a        <- 6        # número de grupos
MS_grupo <- 11.8     # cuadrado medio del grupo
F_val    <- 20.6     # estadístico F
SS_res   <- 13.7     # suma de cuadrados residual
gl_grupo <- a - 1   # grados de libertad del factor = 5
# Cálculos
SS_grupo  <- MS_grupo * gl_grupo        # SS = MS * gl
MS_res    <- MS_grupo / F_val           # MS_res = MS_grupo / F
gl_res    <- round(SS_res / MS_res)     # gl_res = SS_res / MS_res
SS_total  <- SS_grupo + SS_res
gl_total  <- gl_grupo + gl_res
n_por_grupo <- (gl_res / a) + 1        # n = gl_res/a + 1 (balanceado)
N            <- n_por_grupo * a
cat("=== TABLA ANOVA COMPLETADA ===\n")
cat("gl_grupo   =", gl_grupo,  "\n")
cat("SS_grupo   =", SS_grupo,  "\n")
cat("MS_grupo   =", MS_grupo,  "\n")
cat("F          =", F_val,     "\n\n")
cat("gl_res     =", gl_res,    "\n")
cat("SS_res     =", SS_res,    "\n")
cat("MS_res     =", round(MS_res, 4), "\n\n")
cat("gl_total   =", gl_total,  "\n")
cat("SS_total   =", SS_total,  "\n\n")
cat("N total    =", N,          "\n")
cat("n por grupo=", n_por_grupo,"\n")
# P-valor del test F
p_valor_p2 <- pf(F_val, df1 = gl_grupo, df2 = gl_res, lower.tail = FALSE)
cat("\nP-valor:   ", format(p_valor_p2, digits = 4), "\n")
# Medias de los grupos
medias_p2 <- c(y1 = 4.6, y2 = 5.3, y3 = 4.5,
y4 = 6.8, y5 = 7.1, y6 = 8.3)
# Parámetros
alpha_p2    <- 0.05
n_p2        <- n_por_grupo   # observaciones por grupo (diseño balanceado)
gl_error_p2 <- gl_res
# Valor crítico t
t_crit_p2 <- qt(1 - alpha_p2 / 2, df = gl_error_p2)
cat("t crítico (alpha=0.05, gl=", gl_error_p2, "):", round(t_crit_p2, 4), "\n")
# LSD
LSD <- t_crit_p2 * sqrt(2 * MS_res / n_p2)
cat("LSD =", round(LSD, 4), "\n\n")
# Comparaciones por pares
cat("=== COMPARACIONES POR PARES ===\n")
pares <- combn(names(medias_p2), 2)
resultados <- data.frame(
Grupo1 = character(),
Grupo2 = character(),
Diferencia = numeric(),
Significativo = character(),
stringsAsFactors = FALSE
)
for (k in 1:ncol(pares)) {
g1   <- pares[1, k]
g2   <- pares[2, k]
dif  <- abs(medias_p2[g1] - medias_p2[g2])
sig  <- ifelse(dif > LSD, "Sí ***", "No")
resultados <- rbind(resultados,
data.frame(Grupo1 = g1, Grupo2 = g2,
Diferencia = round(dif, 2),
Significativo = sig))
}
print(resultados, row.names = FALSE)
